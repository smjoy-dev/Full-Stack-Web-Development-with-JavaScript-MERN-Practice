// ----- Spread Operator -----

let arr1 = [1, 2];
let arr2 = [3, 4];
let arr3 = [...arr1, ...arr2];
console.log(arr3);
// output: [1, 2, 3, 4]

//Spread operator (...) → array/object er value gula copy ba merge korte use hoy.

// ----- Spread Operator with Object -----

let obj1 = { item1: 1 };  //key:value pair
let obj2 = { ...obj1, item2: 2 };
console.log(obj2);
//output: { item1: 1, item2: 2 }

// ----- Without Spread Operator -----
let arr1 = [1, 2];
let arr2 = [3, 4];
let arr3 = [arr1, arr2];
console.log(arr3);
//output: [[1, 2], [3, 4]]

