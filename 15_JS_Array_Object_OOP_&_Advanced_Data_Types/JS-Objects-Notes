// -------- Set --------
// UNION
let a = new Set([1, 2, 3]);
let b = new Set([4, 5, 6]);
let union = new Set([...a, ...b]);
console.log(union);
//output: Set(6) {1, 2, 3, 4, 5, 6}

____________________________________
// INTERSECTION

let intersection = new Set(
    [...a].filter((x) => b.has(x))
);
console.log(intersection);
//output: Set(0) {}

____________________________________
// DIFFERENCE

let diff = new Set(
    [...a].filter((x) => !b.has(x))
);
console.log(diff);
//output: Set(3) {1, 2, 3}

