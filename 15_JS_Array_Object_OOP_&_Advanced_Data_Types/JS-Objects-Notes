// -------- Rest Parameter --------

function sum(num1, num2) {
    return num1 + num2;
}
console.log(sum(20, 30, 50));
//output: 50
//not dynamic, for calculator

/*Normal parameter → যতগুলো parameter দেওয়া হয় শুধু ততগুলো value নেয়.
Extra value ignore করে. */

function sum(...numbers) {
    return numbers.reduce((acc, curr) => acc + curr, 0);
}
console.log(sum(20, 30, 50));
//output: 100

//or
function sum(...numbers) {
    let total = 0;
    for (let num of numbers) {
        total = total + num;
    }
    return total;
}
console.log(sum(20, 30, 50));

