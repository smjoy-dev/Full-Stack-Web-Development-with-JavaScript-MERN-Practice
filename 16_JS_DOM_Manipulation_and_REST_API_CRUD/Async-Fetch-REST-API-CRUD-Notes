// Fetch API Example
// Server/API থেকে data আনার জন্য use হয়

fetch("https://jsonplaceholder.typicode.com/posts/1")
    .then((res) => res.json())
    .then((data) => console.log(data))
    .catch((err) => console.log(err));

/*
Output:
{
  userId: 1,
  id: 1,
  title: "...",
  body: "..."
}


fetch(): API থেকে data request করে।
res.json(): Response কে JavaScript object এ convert করে।
then(): Successful data receive করে।
catch(): Error handle করে।
Fetch Promise return করে, তাই then() এবং catch() ব্যবহার করা হয়।
*/

