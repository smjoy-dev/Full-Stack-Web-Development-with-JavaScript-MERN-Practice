// Callback Function Example
// একটি function কে অন্য function এর parameter হিসেবে পাঠানো

function greet(name, callback) {
    console.log(`Hello ${name}!`);
    callback();
}
function sayBye() { // callback
    console.log("Goodbye!");
}
greet("Ostad", sayBye);

/*
Output:
Hello Ostad!
Goodbye!
*/

/*
Callback:
একটি function execute হওয়ার পর অন্য function call করার জন্য use হয়।
Function কে argument হিসেবে পাঠানো যায়।
*/

