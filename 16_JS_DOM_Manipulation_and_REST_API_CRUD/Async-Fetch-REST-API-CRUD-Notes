// Promise Example
// Promise state: pending, resolved, reject

const myPromise = new Promise((resolve, reject) => {
    let success = true;
    if(success) {
        resolve("Task Completed");
    }
    else {
        reject("Error Occured!");
    }

});
myPromise
    .then(result => console.log(result))
    .catch(err => console.log(err));

/*
Output:
Task Completed
*/

/*
Promise: Async operation handle করার জন্য use হয়।
resolve(): কাজ successful হলে execute হয়।
reject(): কোনো error হলে execute হয়।
then(): resolve এর result receive করে।
catch(): reject/error handle করে।
*/

