// Async Await Example
// Promise কে সহজভাবে handle করার জন্য async/await use হয়

async function fetchData() {
    const response = await fetch(
        "https://jsonplaceholder.typicode.com/posts/1"
    );
    const data = await response.json();
    console.log(data);
}
fetchData();

/*
Output:

{
  userId: 1,
  id: 1,
  title: "...",
  body: "..."
}

async: Function কে asynchronous বানায় এবং Promise return করে।
await: Promise complete হওয়া পর্যন্ত wait করে।
fetch(): API থেকে data request করে।
response.json(): Response data কে JavaScript object এ convert করে।
async/await দিয়ে then() chain ছাড়া clean ভাবে async code লেখা যায়।
*/
____________________________________________
// CRUD Operation using Fetch API
// GET, POST, PUT, DELETE

const BASE_URL = "https://jsonplaceholder.typicode.com/posts";

____________________________________________

// GET Data

async function getPosts() {
    try {
        const res = await fetch(BASE_URL);
        const data = await res.json();
        console.log("GET:", data);
    } catch(error) {
        console.log(error);
    }
}
getPosts();

/*
GET:
Server/API থেকে data read করার জন্য use হয়।

fetch():
By default GET request করে।
*/

____________________________________________
// CREATE Data (POST)
async function createPost() {
    try {
        const body = {
            userId: 1,
            title: "New Post",
            body: "This is a new Post",
        };
        const res = await fetch(BASE_URL, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(body),
        });
        const data = await res.json();
        console.log("POST:", data);
    } catch(error) {
        console.log(error);
    }
}
createPost();

/*
POST:
Server এ নতুন data create/add করার জন্য use হয়।

JSON.stringify():
JavaScript object কে JSON string এ convert করে।
*/

____________________________________________
// UPDATE Data (PUT)
async function updatePost() {
    try {
        const body = {
            userId: 1,
            title: "Updated Post",
            body: "This post updated",
        };
        const res = await fetch(`${BASE_URL}/1`, {
            method: "PUT",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(body),
        });
        const data = await res.json();
        console.log("UPDATE:", data);
    } catch(error) {
        console.log(error);
    }
}
updatePost();

/*
PUT:
Existing data update/change করার জন্য use হয়।

URL এর শেষে id দিয়ে কোন data update হবে সেটা select করা হয়।
*/

____________________________________________
// DELETE Data
async function deletePost() {
    try {
        const res = await fetch(`${BASE_URL}/1`, {
            method: "DELETE",
        });
        const data = await res.json();
        console.log("DELETE:", data);
    } catch(error) {
        console.log(error);
    }
}
deletePost();

/*
DELETE:
Server থেকে specific data remove করার জন্য use হয়।

method: "DELETE" ব্যবহার করা হয়।
*/
