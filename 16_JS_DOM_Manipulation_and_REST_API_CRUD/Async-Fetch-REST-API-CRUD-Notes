// == vs === Difference
// == (Loose Equality)
// শুধু value check করে, type convert করতে পারে

console.log(5 == "5");
// Output:
// true


// === (Strict Equality)
// value এবং data type দুইটাই check করে
console.log(5 === "5");
// Output:
// false

