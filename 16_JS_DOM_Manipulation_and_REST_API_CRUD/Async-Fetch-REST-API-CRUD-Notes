// Synchronous

console.log("Start");
console.log("Middle");
console.log("End");

/*
Output:
Start
Middle
End
*/

____________________________________________
// Asynchronous

console.log("Start");

setTimeout(() => {
    console.log("Middle");
}, 2000);

console.log("End");


/*
Output:
Start
End
Middle
*/

/*
Synchronous → Wait করে কাজ শেষ করে
Asynchronous → Wait না করে next কাজ করে
Async: Long task background এ চলে।
Program wait না করে next line execute করে।
*/

____________________________________________
// setTimeout(callback, delay)
setTimeout(() => {
    console.log("Hello, World!");
}, 2000);

____________________________________________
// setInterval(callback, interval)

let count = 0;
let intervalId = setInterval(() => {
    count++;
    console.log("Count: " + count);
    if (count === 3) {
        clearInterval(intervalId);
    }
}, 1000);

/*
Output:
Count: 1
Count: 2
Count: 3

1 second পর count 1, 2, 3 print হবে। তারপর clearInterval() call হবে এবং interval বন্ধ হয়ে যাবে।
*/

function greet() {
    console.log("Hi iiiiiiiiii............");
}
setInterval(greet, 1000);
