
# Installation
1st nodejs install
then follow tailwindcss cli
extension Tailwind CSS IntelliSense
always run in terminal - npm run dev


# For auto compile 
  "scripts": {
    "dev": "tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "build": "tailwindcss -i ./src/input.css -o ./src/output.css",
    "watch": "tailwindcss -i ./src/input.css -o ./src/output.css --watch"
  }


# Padding
p-5 = 5*4px  = 20 px
